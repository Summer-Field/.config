	package issues
	
	import (
		"context"
		"time"
	
		"github.com/google/go-github/github"
	)
	
	func getIssues(repo *github.Repository, n int, client *github.Client) []int {
		var issuesCountList []int
		var list []*github.Issue
		opt := &github.IssueListByRepoOptions{
			State: "open",
			Since: time.Now().AddDate(0, 0, 0),
		}
	
		for i := 0; i < n; i++ {
			for {
				l, resp, err := client.Issues.ListByRepo(context.Background(), *repo.Owner.Name, *repo.Name, opt)
				if err != nil {
					return nil, err
				}
				list = append(list, l...)
				if resp.NextPage == 0 {
					break
				}
				opt.Page = resp.NextPage
			}
			issuesCountList[i] = len(list)
			list = nil
			opt.Since = time.Now().AddDate(0, 0, -((i + 1) * 7))
		}
	
		return issuesCountList
	}
